version: '3.8'
services:
  # Backend
  api:
    build: 
      context: ./backend
    container_name: rh_saas_api
    restart: always
    environment:
      - DB_HOST=postgres_db
      - DB_PORT=5432
      - PORT=3000
    depends_on:
      - postgres_db

  # Frontend (Nginx servindo o build)
  web:
    image: nginx:alpine
    container_name: rh_saas_web
    restart: always
    ports:
      - "4001:80"
    volumes:
      - ./frontend-web/dist:/usr/share/nginx/html
      - ./nginx/nginx.conf:/etc/nginx/conf.d/default.conf

  # Bancos e Cache (Já existentes)
  postgres_db:
    image: postgis/postgis:15-3.3
    container_name: rh_saas_postgres
    restart: always
    volumes:
      - ./data/postgres:/var/lib/postgresql/data

  redis_cache:
    image: redis:7-alpine
    container_name: rh_saas_redis
    restart: always

networks:
  default:
    name: rh_saas_network
