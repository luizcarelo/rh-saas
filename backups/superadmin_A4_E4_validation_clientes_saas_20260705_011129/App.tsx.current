import { SuperAdminPlanDetailsPage } from "./pages/SuperAdminPlanDetailsPage";

import { SuperAdminPlaceholderPage } from "./pages/super-admin/SuperAdminPlaceholderPage";

type StoredUserInfo = {
  role?: string;
  user?: {
    role?: string;
  };
  user_info?: {
    role?: string;
  };
};

function readUserInfoFromStorageValue(value: string | null) {
  if (!value) {
    return null;
  }

  try {
    return JSON.parse(value) as StoredUserInfo;
  } catch {
    return null;
  }
}

function getUserInfo() {
  const keys = [
    "user_info",
    "userInfo",
    "user",
    "auth_user",
    "authUser",
    "@RH_USER",
    "@LH_User",
  ];

  for (const key of keys) {
    const localUser = readUserInfoFromStorageValue(localStorage.getItem(key));

    if (localUser) {
      return localUser.user_info || localUser.user || localUser;
    }

    const sessionUser = readUserInfoFromStorageValue(
      sessionStorage.getItem(key),
    );

    if (sessionUser) {
      return sessionUser.user_info || sessionUser.user || sessionUser;
    }
  }

  return null;
}

function superAdminOnly(element: ReactNode) {
  return getUserInfo()?.role === "SUPER_ADMIN" ? element : <Dashboard />;
}

