import {
  Entity,
  Column,
  PrimaryGeneratedColumn,
  CreateDateColumn,
} from 'typeorm';

export enum TimeRecordEventType {
  CLOCK_IN = 'CLOCK_IN',
  BREAK_START = 'BREAK_START',
  BREAK_END = 'BREAK_END',
  CLOCK_OUT = 'CLOCK_OUT',
}

@Entity('time_records')
export class TimeRecord {
  @PrimaryGeneratedColumn('uuid')
  id: string;

  @Column({ name: 'tenant_id' })
  tenantId: string;

  @Column({
    name: 'employee_id',
    nullable: true,
  })
  employeeId: string;

  @Column({
    type: 'decimal',
    precision: 10,
    scale: 7,
    nullable: true,
  })
  latitude: number;

  @Column({
    type: 'decimal',
    precision: 10,
    scale: 7,
    nullable: true,
  })
  longitude: number;

  @Column({
    name: 'event_type',
    length: 20,
    default: TimeRecordEventType.CLOCK_IN,
  })
  eventType: string;

  @CreateDateColumn()
  timestamp: Date;
}