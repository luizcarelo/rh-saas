import { Injectable } from '@nestjs/common';
import { InjectRepository } from '@nestjs/typeorm';
import { Repository } from 'typeorm';

import {
  TimeRecord,
  TimeRecordEventType,
} from './time-record.entity';

import { AuditService } from '../audit/audit.service';

@Injectable()
export class TimeRecordsService {
  constructor(
    @InjectRepository(TimeRecord)
    private readonly repo: Repository<TimeRecord>,

    private readonly auditService: AuditService,
  ) {}

  private async registerEvent(
    tenantId: string,
    employeeId: string,
    latitude: number,
    longitude: number,
    eventType: TimeRecordEventType,
  ) {
    const record = this.repo.create({
      tenantId,
      employeeId,
      latitude,
      longitude,
      eventType,
    });

    const savedRecord =
      await this.repo.save(record);

    await this.auditService.create({
      tenantId,
      entityId: savedRecord.id,
      action: eventType,
      entityType: 'TimeRecord',
      details: JSON.stringify({
        employeeId,
        latitude,
        longitude,
      }),
    });

    return savedRecord;
  }

  async clockIn(
    tenantId: string,
    employeeId: string,
    latitude: number,
    longitude: number,
  ) {
    return this.registerEvent(
      tenantId,
      employeeId,
      latitude,
      longitude,
      TimeRecordEventType.CLOCK_IN,
    );
  }

  async breakStart(
    tenantId: string,
    employeeId: string,
    latitude: number,
    longitude: number,
  ) {
    return this.registerEvent(
      tenantId,
      employeeId,
      latitude,
      longitude,
      TimeRecordEventType.BREAK_START,
    );
  }

  async breakEnd(
    tenantId: string,
    employeeId: string,
    latitude: number,
    longitude: number,
  ) {
    return this.registerEvent(
      tenantId,
      employeeId,
      latitude,
      longitude,
      TimeRecordEventType.BREAK_END,
    );
  }

  async clockOut(
    tenantId: string,
    employeeId: string,
    latitude: number,
    longitude: number,
  ) {
    return this.registerEvent(
      tenantId,
      employeeId,
      latitude,
      longitude,
      TimeRecordEventType.CLOCK_OUT,
    );
  }

  async findAll(tenantId: string) {
    return this.repo.find({
      where: { tenantId },
      order: {
        timestamp: 'DESC',
      },
    });
  }

  async getEmployeeWorkStatus(
    tenantId: string,
    employeeId: string,
  ) {
    const lastEvent =
      await this.repo.findOne({
        where: {
          tenantId,
          employeeId,
        },
        order: {
          timestamp: 'DESC',
        },
      });

    if (!lastEvent) {
      return {
        working: false,
        onBreak: false,
        shiftEnded: true,
        lastEvent: null,
      };
    }

    return {
      working:
        lastEvent.eventType ===
          TimeRecordEventType.CLOCK_IN ||
        lastEvent.eventType ===
          TimeRecordEventType.BREAK_END,

      onBreak:
        lastEvent.eventType ===
        TimeRecordEventType.BREAK_START,

      shiftEnded:
        lastEvent.eventType ===
        TimeRecordEventType.CLOCK_OUT,

      lastEvent:
        lastEvent.eventType,
    };
  }

  // Gera o layout oficial do Arquivo Fonte de Dados (AFD)
  // conforme Portaria 671 MTE
  async generateAfd(
    tenantId: string,
  ): Promise<string> {
    const records =
      await this.findAll(tenantId);

    let nsr = 1;
    let afdContent = '';

    const cnpj =
      '12345678000100'.padEnd(14, '0');

    afdContent +=
      `00000000011${cnpj}SAAS RH PRO EMPRESA TESTE                 00001\r\n`;

    for (const rec of records) {
      const seq = String(nsr++)
        .padStart(9, '0');

      const date =
        new Date(rec.timestamp);

      const dia = String(
        date.getDate(),
      ).padStart(2, '0');

      const mes = String(
        date.getMonth() + 1,
      ).padStart(2, '0');

      const ano =
        date.getFullYear();

      const hora = String(
        date.getHours(),
      ).padStart(2, '0');

      const min = String(
        date.getMinutes(),
      ).padStart(2, '0');

      const cpf =
        '12345678901';

      afdContent +=
        `${seq}3${dia}${mes}${ano}${hora}${min}${cpf}4B6F\r\n`;
    }

    return afdContent;
  }
}