import { BrowserRouter, Route, Routes } from "react-router-dom";
import { Toaster } from "react-hot-toast";

import { AdminLayout } from "./layouts/AdminLayout";
import { EmployeeLayout } from "./layouts/EmployeeLayout";

import { ProtectedRoute } from "./components/ProtectedRoute";
import { LiveTrackingFoundationPage } from "./pages/LiveTrackingFoundationPage";
import { getUserInfo } from "./lib/api";

import { Login } from "./pages/Login";
import { Dashboard } from "./pages/Dashboard";
import { EmployeesPage } from "./pages/EmployeesPage";
import { EmployeeDetailsPage } from "./pages/EmployeeDetailsPage";
import { DocumentsPage } from "./pages/DocumentsPage";
import { UsersPage } from "./pages/UsersPage";
import { AuditLogsPage } from "./pages/AuditLogsPage";
import { TimeTrackingPage } from "./pages/TimeTrackingPage";
import { ClockInPage } from "./pages/ClockInPage";
import { EmployeeDashboard } from "./pages/EmployeeDashboard";

import { SuperAdminDashboard } from "./pages/SuperAdminDashboard";
import { SuperAdminClientsPage } from "./pages/SuperAdminClientsPage";
import { SuperAdminClientDetailsPage } from "./pages/SuperAdminClientDetailsPage";
import { SuperAdminClientDashboardPage } from "./pages/SuperAdminClientDashboardPage";
import { SuperAdminClientAuditPage } from "./pages/SuperAdminClientAuditPage";
import { SuperAdminClientModulesPage } from "./pages/SuperAdminClientModulesPage";
import { SuperAdminClientModulesAuditPage } from "./pages/SuperAdminClientModulesAuditPage";

import { SuperAdminPlansPage } from "./pages/SuperAdminPlansPage";
import { SuperAdminPlanDetailsPage } from "./pages/SuperAdminPlanDetailsPage";
import { SuperAdminPlanCreatePage } from "./pages/SuperAdminPlanCreatePage";

import { AnalyticsPage } from "./pages/AnalyticsPage";
import { SuperAdminPlaceholderPage } from "./pages/super-admin/SuperAdminPlaceholderPage";

export default function App() {
  return (
    <BrowserRouter>
      <Routes>

        <Route
          path="/login"
          element={<Login />}
        />

        <Route element={<ProtectedRoute />}>
          <Route element={<AdminLayout />}>

            <Route
              path="/"
              element={<Dashboard />}
            />

            <Route
              path="/colaboradores"
              element={<EmployeesPage />}
            />

            <Route
            path="/colaboradores/:id"
            element={<EmployeeDetailsPage />}
            />

            
<Route
  path="/documentos"
  element={<DocumentsPage />}
/>

<Route
  path="/usuarios"
    element={<UsersPage />}
/>
<Route
  path="/analytics"
  element={<AnalyticsPage />}
/>

            <Route
              path="/audit"
              element={<AuditLogsPage />}
            />

            <Route
              path="/ponto"
              element={<TimeTrackingPage />}
            />

            <Route
              path="/registrar-ponto"
              element={<ClockInPage />}
            />


            <Route
              path="/live-tracking-foundation"
              element={<LiveTrackingFoundationPage />}
            />

            <Route
              path="/super-admin"
              element={
                getUserInfo()?.role === "SUPER_ADMIN"
                  ? <SuperAdminDashboard />
                  : <Dashboard />
              }
            />

            <Route
              path="/super-admin/clientes"
              element={
                getUserInfo()?.role === "SUPER_ADMIN"
                  ? <SuperAdminClientsPage />
                  : <Dashboard />
              }
            />

            <Route
              path="/super-admin/clientes/:id"
              element={
                getUserInfo()?.role === "SUPER_ADMIN"
                  ? <SuperAdminClientDetailsPage />
                  : <Dashboard />
              }
            />

            <Route
              path="/super-admin/clientes/:id/dashboard"
              element={
                getUserInfo()?.role === "SUPER_ADMIN"
                  ? <SuperAdminClientDashboardPage />
                  : <Dashboard />
              }
            />

            <Route
              path="/super-admin/clientes/:id/audit"
              element={
                getUserInfo()?.role === "SUPER_ADMIN"
                  ? <SuperAdminClientAuditPage />
                  : <Dashboard />
              }
            />

            <Route
              path="/super-admin/clientes/:id/modules"
              element={
                getUserInfo()?.role === "SUPER_ADMIN"
                  ? <SuperAdminClientModulesPage />
                  : <Dashboard />
              }
            />

            <Route
              path="/super-admin/clientes/:id/modules/audit"
              element={
                getUserInfo()?.role === "SUPER_ADMIN"
                  ? <SuperAdminClientModulesAuditPage />
                  : <Dashboard />
              }
            />

            <Route
              path="/super-admin/planos"
              element={
                getUserInfo()?.role === "SUPER_ADMIN"
                  ? <SuperAdminPlansPage />
                  : <Dashboard />
              }
            />

            <Route
              path="/super-admin/planos/novo"
              element={
                getUserInfo()?.role === "SUPER_ADMIN"
                  ? <SuperAdminPlanCreatePage />
                  : <Dashboard />
              }
            />

            <Route
                path="/super-admin/planos/:id"
                element={
                  getUserInfo()?.role === "SUPER_ADMIN"
                    ? <SuperAdminPlanDetailsPage />
                    : <Dashboard />
                }
              />

              <Route
                path="/super-admin/clientes/dashboard"
                element={(
                  <SuperAdminPlaceholderPage
                    title="Dashboard de Clientes"
                    description="Visão consolidada de indicadores por cliente SaaS, incluindo status de implantação, módulos ativos e alertas operacionais."
                    priority="Média"
                    items={['Indicadores por cliente', 'Clientes ativos e suspensos', 'Módulos contratados', 'Alertas operacionais']}
                    nextSteps={['Definir métricas por tenant.', 'Validar endpoints agregados.', 'Criar cards analíticos reais.']}
                  />
                )}
              />

              <Route
                path="/super-admin/clientes/novo"
                element={(
                  <SuperAdminPlaceholderPage
                    title="Novo Cliente SaaS"
                    description="Preparação do fluxo de cadastro de novos clientes SaaS, incluindo dados cadastrais, plano inicial e módulos contratados."
                    priority="Alta"
                    items={['Dados do cliente', 'Tenant inicial', 'Plano contratado', 'Módulos habilitados']}
                    nextSteps={['Validar contrato backend de criação de cliente.', 'Definir campos obrigatórios.', 'Implementar formulário de cadastro.']}
                  />
                )}
              />

              <Route
                path="/super-admin/empresas"
                element={(
                  <SuperAdminPlaceholderPage
                    title="Empresas e Filiais"
                    description="Área para gestão de empresas, matrizes e filiais vinculadas aos clientes SaaS."
                    priority="Alta"
                    items={['Matriz', 'Filiais', 'CNPJ', 'Endereço completo', 'Status ativo/inativo']}
                    nextSteps={['Mapear tabela real de empresas/filiais.', 'Validar endpoints existentes.', 'Criar CRUD de empresas e filiais.']}
                  />
                )}
              />

              <Route
                path="/super-admin/planos/recursos"
                element={(
                  <SuperAdminPlaceholderPage
                    title="Recursos dos Planos"
                    description="Área para definir quais recursos e módulos pertencem a cada plano SaaS."
                    priority="Média"
                    items={['Ponto eletrônico', 'Documentos', 'Mobile', 'Live Tracking', 'Holerites', 'Relatórios']}
                    nextSteps={['Mapear módulos/features existentes.', 'Definir matriz plano x recurso.', 'Criar tela de associação.']}
                  />
                )}
              />

              <Route
                path="/super-admin/modulos"
                element={(
                  <SuperAdminPlaceholderPage
                    title="Módulos SaaS"
                    description="Catálogo dos módulos disponíveis na plataforma SaaS."
                    priority="Alta"
                    items={['Ponto', 'Documentos', 'Assinaturas', 'Mobile', 'Live Tracking', 'Holerites']}
                    nextSteps={['Validar tabela de módulos/features.', 'Definir status por módulo.', 'Criar CRUD ou catálogo administrável.']}
                  />
                )}
              />

              <Route
                path="/super-admin/modulos/clientes"
                element={(
                  <SuperAdminPlaceholderPage
                    title="Módulos por Cliente"
                    description="Controle de módulos habilitados por cliente SaaS."
                    priority="Alta"
                    items={['Cliente', 'Plano', 'Módulos ativos', 'Feature flags', 'Histórico de alterações']}
                    nextSteps={['Definir vínculo tenant x módulo.', 'Criar endpoint de ativação/desativação.', 'Criar tela de permissões por cliente.']}
                  />
                )}
              />

              <Route
                path="/super-admin/usuarios"
                element={(
                  <SuperAdminPlaceholderPage
                    title="Usuários Administrativos"
                    description="Gestão de usuários administrativos da plataforma SaaS."
                    priority="Alta"
                    items={['SUPER_ADMIN', 'TENANT_ADMIN', 'RH_ADMIN', 'Status ativo/inativo', 'Reset controlado de senha']}
                    nextSteps={['Validar endpoints de usuários.', 'Definir permissões por perfil.', 'Criar CRUD administrativo seguro.']}
                  />
                )}
              />

              <Route
                path="/super-admin/auditoria"
                element={(
                  <SuperAdminPlaceholderPage
                    title="Auditoria SaaS"
                    description="Consulta de ações administrativas, logs críticos e eventos relevantes da operação SaaS."
                    priority="Média"
                    items={['Usuário', 'Cliente', 'Ação', 'Data/hora', 'Módulo', 'Evento crítico']}
                    nextSteps={['Validar tabelas de auditoria/logs.', 'Criar filtros por usuário e cliente.', 'Criar consulta paginada.']}
                  />
                )}
              />

              <Route
                path="/super-admin/configuracoes"
                element={(
                  <SuperAdminPlaceholderPage
                    title="Configurações SaaS"
                    description="Parâmetros globais da plataforma, identidade visual padrão e políticas gerais."
                    priority="Média"
                    items={['Parâmetros globais', 'Identidade visual', 'Políticas de segurança', 'Limites globais']}
                    nextSteps={['Definir parâmetros globais suportados.', 'Validar persistência no backend.', 'Criar tela de configuração segura.']}
                  />
                )}
              />

          </Route>
        </Route>

        <Route element={<ProtectedRoute />}>
<Route element={<EmployeeLayout />}>
            <Route
              path="/meu-painel"
              element={<EmployeeDashboard />}
            />
          </Route>
        </Route>

      </Routes>

      <Toaster position="top-right" />
    </BrowserRouter>
  );
}
