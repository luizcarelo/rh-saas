import {
  Injectable,
  NotFoundException,
} from '@nestjs/common';

import { DataSource } from 'typeorm';

@Injectable()
export class SuperAdminService {

  constructor(
    private readonly dataSource: DataSource,
  ) {}

  async health() {
    return {
      status: 'ok',
      module: 'super-admin',
    };
  }

  async listClients() {

    return this.dataSource.query(`
      SELECT
        sc.id,
        sc.slug,
        sc.status,
        sp.code as "planCode",
        sp.name as "planName"
      FROM saas_clients sc
      LEFT JOIN saas_plans sp
        ON sp.id = sc.plan_id
      ORDER BY sc.slug
    `);
  }

  async getClientDetails(id: string) {

    const clientRows = await this.dataSource.query(`
      SELECT *
      FROM saas_clients
      WHERE id = $1
    `,[id]);

    if (!clientRows.length) {
      throw new NotFoundException(
        'Cliente não encontrado'
      );
    }

    const client = clientRows[0];

    const plan = await this.dataSource.query(`
      SELECT *
      FROM saas_plans
      WHERE id = $1
    `,[client.plan_id]);

    const modules = await this.dataSource.query(`
      SELECT
        module_code,
        enabled
      FROM tenant_module_flags
      WHERE client_id = $1
      ORDER BY module_code
    `,[id]);

    const company = await this.dataSource.query(`
      SELECT *
      FROM hr_companies
      WHERE client_id = $1
      LIMIT 1
    `,[id]);

    const employees = await this.dataSource.query(`
      SELECT COUNT(*)::int total
      FROM hr_employee_profiles
      WHERE client_id = $1
    `,[id]);

    const documents = await this.dataSource.query(`
      SELECT COUNT(*)::int total
      FROM documents_foundation
      WHERE client_id = $1
    `,[id]);

    const payslips = await this.dataSource.query(`
      SELECT COUNT(*)::int total
      FROM payslips_foundation
      WHERE client_id = $1
    `,[id]);

    return {
      client,
      plan: plan[0] ?? null,
      company: company[0] ?? null,
      modules,
      statistics: {
        employees: employees[0]?.total ?? 0,
        documents: documents[0]?.total ?? 0,
        payslips: payslips[0]?.total ?? 0,
      },
    };
  }

  async getModules(clientId: string) {

    return this.dataSource.query(`
      SELECT
        module_code,
        enabled
      FROM tenant_module_flags
      WHERE client_id = $1
      ORDER BY module_code
    `,[clientId]);
  }

  

  async getModuleAudit(clientId: string) {

    return this.dataSource.query(`
      SELECT
        module_code,
        old_enabled,
        new_enabled,
        changed_by_email,
        created_at
      FROM tenant_module_audit
      WHERE client_id = $1
      ORDER BY created_at DESC
    `,[clientId]);
  }


  async updateModule(
    clientId: string,
    moduleCode: string,
    enabled: boolean,
  ) {

    const currentRows =
      await this.dataSource.query(`
        SELECT enabled
        FROM tenant_module_flags
        WHERE client_id = $1
        AND module_code = $2
      `,[clientId,moduleCode]);

    const oldEnabled =
      currentRows.length
        ? currentRows[0].enabled
        : null;

    await this.dataSource.query(`
      UPDATE tenant_module_flags
         SET enabled = $3
       WHERE client_id = $1
         AND module_code = $2
    `,[clientId,moduleCode,enabled]);

    await this.dataSource.query(`
      INSERT INTO tenant_module_audit(
        client_id,
        module_code,
        old_enabled,
        new_enabled,
        changed_by_email
      )
      VALUES(
        $1,$2,$3,$4,$5
      )
    `,[
      clientId,
      moduleCode,
      oldEnabled,
      enabled,
      'SUPER_ADMIN'
    ]);

    return {
      clientId,
      moduleCode,
      oldEnabled,
      enabled,
    };
  }



  async getDashboard() {

    const clients =
      await this.dataSource.query(`
        SELECT
          COUNT(*)::int total,
          COUNT(*) FILTER (
            WHERE status = 'ACTIVE'
          )::int active,
          COUNT(*) FILTER (
            WHERE status <> 'ACTIVE'
          )::int inactive
        FROM saas_clients
      `);

    const plans =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM saas_plans
      `);

    const users =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM users
      `);

    const employees =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM hr_employee_profiles
      `);

    const documents =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM documents_foundation
      `);

    const payslips =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM payslips_foundation
      `);

    const modules =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM tenant_module_flags
        WHERE enabled = true
      `);

    const audit =
      await this.dataSource.query(`
        SELECT
          module_code,
          old_enabled,
          new_enabled,
          changed_by_email,
          created_at
        FROM tenant_module_audit
        ORDER BY created_at DESC
        LIMIT 10
      `);

    return {
      clients: clients[0],
      plans: plans[0],
      users: users[0],
      employees: employees[0],
      documents: {
        documents: documents[0]?.total ?? 0,
        payslips: payslips[0]?.total ?? 0,
      },
      modules: {
        enabled: modules[0]?.total ?? 0,
      },
      audit,
    };
  }




  async getClientDashboard(clientId: string) {

    const clientRows =
      await this.dataSource.query(`
        SELECT *
        FROM saas_clients
        WHERE id = $1
      `,[clientId]);

    if (!clientRows.length) {
      throw new NotFoundException(
        'Cliente não encontrado'
      );
    }

    const client = clientRows[0];

    const plan =
      await this.dataSource.query(`
        SELECT *
        FROM saas_plans
        WHERE id = $1
      `,[client.plan_id]);

    const users =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM users
        WHERE tenant_id = $1
      `,[client.tenant_id]);

    const employees =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM hr_employee_profiles
        WHERE client_id = $1
      `,[clientId]);

    const documents =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM documents_foundation
        WHERE client_id = $1
      `,[clientId]);

    const payslips =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM payslips_foundation
        WHERE client_id = $1
      `,[clientId]);

    const enabledModules =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM tenant_module_flags
        WHERE client_id = $1
        AND enabled = true
      `,[clientId]);

    const disabledModules =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM tenant_module_flags
        WHERE client_id = $1
        AND enabled = false
      `,[clientId]);

    const audit =
      await this.dataSource.query(`
        SELECT
          module_code,
          old_enabled,
          new_enabled,
          changed_by_email,
          created_at
        FROM tenant_module_audit
        WHERE client_id = $1
        ORDER BY created_at DESC
        LIMIT 20
      `,[clientId]);

    return {
      client,
      plan: plan[0] ?? null,
      users: users[0],
      employees: employees[0],
      documents: {
        documents: documents[0]?.total ?? 0,
        payslips: payslips[0]?.total ?? 0,
      },
      modules: {
        enabled: enabledModules[0]?.total ?? 0,
        disabled: disabledModules[0]?.total ?? 0,
      },
      audit,
    };
  }




  async listPlans() {

    return this.dataSource.query(`
      SELECT *
      FROM saas_plans
      ORDER BY code
    `);
  }

  async createPlan(dto: any) {

    const rows =
      await this.dataSource.query(`
        INSERT INTO saas_plans(
          code,
          name,
          description,
          is_active,
          created_at,
          updated_at
        )
        VALUES(
          $1,$2,$3,true,NOW(),NOW()
        )
        RETURNING *
      `,[
        dto.code,
        dto.name,
        dto.description ?? null
      ]);

    return rows[0];
  }

  async updatePlan(
    id: string,
    dto: any,
  ) {

    const current =
      await this.dataSource.query(`
        SELECT *
        FROM saas_plans
        WHERE id = $1
      `,[id]);

    if (!current.length) {
      throw new NotFoundException(
        'Plano não encontrado'
      );
    }

    const plan = current[0];

    const rows =
      await this.dataSource.query(`
        UPDATE saas_plans
           SET
             name = $2,
             description = $3,
             is_active = $4,
             updated_at = NOW()
         WHERE id = $1
     RETURNING *
      `,[
        id,
        dto.name ?? plan.name,
        dto.description ?? plan.description,
        dto.is_active ?? plan.is_active
      ]);

    return rows[0];
  }


}
