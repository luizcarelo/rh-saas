import {
  Injectable,
  NotFoundException,
} from '@nestjs/common';

import { DataSource } from 'typeorm';
import * as os from 'os';
import { execSync } from 'child_process';

@Injectable()
export class SuperAdminService {

  constructor(
    private readonly dataSource: DataSource,
  ) {}

  async health() {
    return {
      status: 'ok',
      module: 'super-admin',
    };
  }

  async listClients() {

    return this.dataSource.query(`
      SELECT
        sc.id,
        sc.slug,
        sc.status,
        sp.code as "planCode",
        sp.name as "planName"
      FROM saas_clients sc
      LEFT JOIN saas_plans sp
        ON sp.id = sc.plan_id
      ORDER BY sc.slug
    `);
  }

  async getClientDetails(id: string) {

    const clientRows = await this.dataSource.query(`
      SELECT *
      FROM saas_clients
      WHERE id = $1
    `,[id]);

    if (!clientRows.length) {
      throw new NotFoundException(
        'Cliente não encontrado'
      );
    }

    const client = clientRows[0];

    const plan = await this.dataSource.query(`
      SELECT *
      FROM saas_plans
      WHERE id = $1
    `,[client.plan_id]);

    const modules = await this.dataSource.query(`
      SELECT
        module_code,
        enabled
      FROM tenant_module_flags
      WHERE client_id = $1
      ORDER BY module_code
    `,[id]);

    const company = await this.dataSource.query(`
      SELECT *
      FROM hr_companies
      WHERE client_id = $1
      LIMIT 1
    `,[id]);

    const employees = await this.dataSource.query(`
      SELECT COUNT(*)::int total
      FROM hr_employee_profiles
      WHERE client_id = $1
    `,[id]);

    const documents = await this.dataSource.query(`
      SELECT COUNT(*)::int total
      FROM documents_foundation
      WHERE client_id = $1
    `,[id]);

    const payslips = await this.dataSource.query(`
      SELECT COUNT(*)::int total
      FROM payslips_foundation
      WHERE client_id = $1
    `,[id]);

    return {
      client,
      plan: plan[0] ?? null,
      company: company[0] ?? null,
      modules,
      statistics: {
        employees: employees[0]?.total ?? 0,
        documents: documents[0]?.total ?? 0,
        payslips: payslips[0]?.total ?? 0,
      },
    };
  }

  async getModules(clientId: string) {

    return this.dataSource.query(`
      SELECT
        module_code,
        enabled
      FROM tenant_module_flags
      WHERE client_id = $1
      ORDER BY module_code
    `,[clientId]);
  }

  

  async getModuleAudit(clientId: string) {

    return this.dataSource.query(`
      SELECT
        module_code,
        old_enabled,
        new_enabled,
        changed_by_email,
        created_at
      FROM tenant_module_audit
      WHERE client_id = $1
      ORDER BY created_at DESC
    `,[clientId]);
  }


  async updateModule(
    clientId: string,
    moduleCode: string,
    enabled: boolean,
  ) {

    const currentRows =
      await this.dataSource.query(`
        SELECT enabled
        FROM tenant_module_flags
        WHERE client_id = $1
        AND module_code = $2
      `,[clientId,moduleCode]);

    const oldEnabled =
      currentRows.length
        ? currentRows[0].enabled
        : null;

    await this.dataSource.query(`
      UPDATE tenant_module_flags
         SET enabled = $3
       WHERE client_id = $1
         AND module_code = $2
    `,[clientId,moduleCode,enabled]);

    await this.dataSource.query(`
      INSERT INTO tenant_module_audit(
        client_id,
        module_code,
        old_enabled,
        new_enabled,
        changed_by_email
      )
      VALUES(
        $1,$2,$3,$4,$5
      )
    `,[
      clientId,
      moduleCode,
      oldEnabled,
      enabled,
      'SUPER_ADMIN'
    ]);

    return {
      clientId,
      moduleCode,
      oldEnabled,
      enabled,
    };
  }



  async getDashboard() {

    const clients =
      await this.dataSource.query(`
        SELECT
          COUNT(*)::int total,
          COUNT(*) FILTER (
            WHERE status = 'ACTIVE'
          )::int active,
          COUNT(*) FILTER (
            WHERE status <> 'ACTIVE'
          )::int inactive
        FROM saas_clients
      `);

    const plans =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM saas_plans
      `);

    const users =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM users
      `);

    const employees =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM hr_employee_profiles
      `);

    const documents =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM documents_foundation
      `);

    const payslips =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM payslips_foundation
      `);

    const modules =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM tenant_module_flags
        WHERE enabled = true
      `);

    const audit =
      await this.dataSource.query(`
        SELECT
          module_code,
          old_enabled,
          new_enabled,
          changed_by_email,
          created_at
        FROM tenant_module_audit
        ORDER BY created_at DESC
        LIMIT 10
      `);

    return {
      clients: clients[0],
      plans: plans[0],
      users: users[0],
      employees: employees[0],
      documents: {
        documents: documents[0]?.total ?? 0,
        payslips: payslips[0]?.total ?? 0,
      },
      modules: {
        enabled: modules[0]?.total ?? 0,
      },
      audit,
    };
  }




  async getClientDashboard(clientId: string) {

    const clientRows =
      await this.dataSource.query(`
        SELECT *
        FROM saas_clients
        WHERE id = $1
      `,[clientId]);

    if (!clientRows.length) {
      throw new NotFoundException(
        'Cliente não encontrado'
      );
    }

    const client = clientRows[0];

    const plan =
      await this.dataSource.query(`
        SELECT *
        FROM saas_plans
        WHERE id = $1
      `,[client.plan_id]);

    const users =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM users
        WHERE tenant_id = $1
      `,[client.tenant_id]);

    const employees =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM hr_employee_profiles
        WHERE client_id = $1
      `,[clientId]);

    const documents =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM documents_foundation
        WHERE client_id = $1
      `,[clientId]);

    const payslips =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM payslips_foundation
        WHERE client_id = $1
      `,[clientId]);

    const enabledModules =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM tenant_module_flags
        WHERE client_id = $1
        AND enabled = true
      `,[clientId]);

    const disabledModules =
      await this.dataSource.query(`
        SELECT COUNT(*)::int total
        FROM tenant_module_flags
        WHERE client_id = $1
        AND enabled = false
      `,[clientId]);

    const audit =
      await this.dataSource.query(`
        SELECT
          module_code,
          old_enabled,
          new_enabled,
          changed_by_email,
          created_at
        FROM tenant_module_audit
        WHERE client_id = $1
        ORDER BY created_at DESC
        LIMIT 20
      `,[clientId]);

    return {
      client,
      plan: plan[0] ?? null,
      users: users[0],
      employees: employees[0],
      documents: {
        documents: documents[0]?.total ?? 0,
        payslips: payslips[0]?.total ?? 0,
      },
      modules: {
        enabled: enabledModules[0]?.total ?? 0,
        disabled: disabledModules[0]?.total ?? 0,
      },
      audit,
    };
  }




  async listPlans() {

    return this.dataSource.query(`
      SELECT *
      FROM saas_plans
      ORDER BY code
    `);
  }

  async createPlan(dto: any) {

    const rows =
      await this.dataSource.query(`
        INSERT INTO saas_plans(
          code,
          name,
          description,
          is_active,
          created_at,
          updated_at
        )
        VALUES(
          $1,$2,$3,true,NOW(),NOW()
        )
        RETURNING *
      `,[
        dto.code,
        dto.name,
        dto.description ?? null
      ]);

    return rows[0];
  }

  async updatePlan(
    id: string,
    dto: any,
  ) {

    const current =
      await this.dataSource.query(`
        SELECT *
        FROM saas_plans
        WHERE id = $1
      `,[id]);

    if (!current.length) {
      throw new NotFoundException(
        'Plano não encontrado'
      );
    }

    const plan = current[0];

    const rows =
      await this.dataSource.query(`
        UPDATE saas_plans
           SET
             name = $2,
             description = $3,
             is_active = $4,
             updated_at = NOW()
         WHERE id = $1
     RETURNING *
      `,[
        id,
        dto.name ?? plan.name,
        dto.description ?? plan.description,
        dto.is_active ?? plan.is_active
      ]);

    return rows[0];
  }




  async createClient(dto: any) {

    const queryRunner =
      this.dataSource.createQueryRunner();

    await queryRunner.connect();
    await queryRunner.startTransaction();

    try {

      const tenantRows =
        await queryRunner.query(`
          INSERT INTO tenants(
            cnpj,
            corporate_name,
            trading_name
          )
          VALUES(
            $1,$2,$3
          )
          RETURNING *
        `,[
          dto.documentNumber,
          dto.legalName,
          dto.tradeName
        ]);

      const tenant = tenantRows[0];

      const clientRows =
        await queryRunner.query(`
          INSERT INTO saas_clients(
            tenant_id,
            plan_id,
            slug,
            trade_name,
            legal_name,
            document_number
          )
          VALUES(
            $1,$2,$3,$4,$5,$6
          )
          RETURNING *
        `,[
          tenant.id,
          dto.planId,
          dto.slug,
          dto.tradeName,
          dto.legalName,
          dto.documentNumber
        ]);

      const client = clientRows[0];

      await queryRunner.query(`
        INSERT INTO hr_companies(
          client_id,
          legal_name,
          trade_name,
          document_number
        )
        VALUES(
          $1,$2,$3,$4
        )
      `,[
        client.id,
        dto.legalName,
        dto.tradeName,
        dto.documentNumber
      ]);

      await queryRunner.commitTransaction();

      return {
        tenant,
        client
      };

    } catch(error) {

      await queryRunner.rollbackTransaction();

      throw error;

    } finally {

      await queryRunner.release();

    }
  }



  async updateClient(
    id: string,
    dto: any,
  ) {

    const rows =
      await this.dataSource.query(`
        SELECT *
        FROM saas_clients
        WHERE id = $1
      `,[id]);

    if (!rows.length) {
      throw new NotFoundException(
        'Cliente não encontrado'
      );
    }

    const current = rows[0];

    const updated =
      await this.dataSource.query(`
        UPDATE saas_clients
           SET
             trade_name = $2,
             legal_name = $3,
             document_number = $4,
             timezone = $5,
             default_locale = $6,
             notes = $7,
             plan_id = $8,
             updated_at = NOW()
         WHERE id = $1
     RETURNING *
      `,[
        id,
        dto.tradeName ?? current.trade_name,
        dto.legalName ?? current.legal_name,
        dto.documentNumber ?? current.document_number,
        dto.timezone ?? current.timezone,
        dto.defaultLocale ?? current.default_locale,
        dto.notes ?? current.notes,
        dto.planId ?? current.plan_id
      ]);

    const result = updated[0];

    const auditFields = [
      ['trade_name', current.trade_name, result.trade_name],
      ['legal_name', current.legal_name, result.legal_name],
      ['document_number', current.document_number, result.document_number],
      ['timezone', current.timezone, result.timezone],
      ['default_locale', current.default_locale, result.default_locale],
      ['notes', current.notes, result.notes],
      ['plan_id', current.plan_id, result.plan_id],
    ];

    for (const [field, oldValue, newValue] of auditFields) {

      if ((oldValue ?? '') !== (newValue ?? '')) {

        await this.dataSource.query(`
          INSERT INTO tenant_client_audit(
            client_id,
            field_name,
            old_value,
            new_value,
            changed_by
          )
          VALUES(
            $1,$2,$3,$4,$5
          )
        `,[
          id,
          field,
          String(oldValue ?? ''),
          String(newValue ?? ''),
          'SUPER_ADMIN'
        ]);
      }
    }

    return result;
  }

  async updateClientStatus(
    id: string,
    status: string,
  ) {

    const currentRows =
      await this.dataSource.query(`
        SELECT *
        FROM saas_clients
        WHERE id = $1
      `,[id]);

    if (!currentRows.length) {
      throw new NotFoundException(
        'Cliente não encontrado'
      );
    }

    const current = currentRows[0];

    const rows =
      await this.dataSource.query(`
        UPDATE saas_clients
           SET
             status = $2,
             updated_at = NOW()
         WHERE id = $1
     RETURNING *
      `,[id,status]);

    await this.dataSource.query(`
      INSERT INTO tenant_client_audit(
        client_id,
        field_name,
        old_value,
        new_value,
        changed_by
      )
      VALUES(
        $1,$2,$3,$4,$5
      )
    `,[
      id,
      'status',
      current.status,
      status,
      'SUPER_ADMIN'
    ]);

    return rows[0];
  }




  async getClientAudit(
    clientId: string,
  ) {

    return this.dataSource.query(`
      SELECT
        field_name,
        old_value,
        new_value,
        changed_by,
        created_at
      FROM tenant_client_audit
      WHERE client_id = $1
      ORDER BY created_at DESC
    `,[clientId]);
  }




  async systemHealth() {

    await this.dataSource.query(
      'SELECT 1'
    );

    return {
      api: 'UP',
      database: 'UP',
      timestamp: new Date().toISOString(),
    };
  }

  async databaseStatus() {

    const rows =
      await this.dataSource.query(`
        SELECT
          COUNT(*)::int as connections
        FROM pg_stat_activity
      `);

    return {
      status: 'UP',
      connections:
        rows[0]?.connections ?? 0,
    };
  }




  async systemStorage() {

    const raw =
      execSync('df -k /')
        .toString()
        .split('\n')[1]
        .trim()
        .split(/\s+/);

    return {
      filesystem: raw[0],
      usedPercent: Number(
        raw[4].replace('%','')
      ),
      availableGb:
        Number(raw[3]) /
        1024 /
        1024,
    };
  }

  async systemMetrics() {

    const totalMem =
      os.totalmem();

    const freeMem =
      os.freemem();

    const usedMem =
      totalMem - freeMem;

    return {
      memoryUsedMb:
        Math.round(
          usedMem / 1024 / 1024
        ),

      memoryTotalMb:
        Math.round(
          totalMem / 1024 / 1024
        ),

      memoryPercent:
        Math.round(
          (usedMem / totalMem) * 100
        ),

      uptimeSeconds:
        Math.round(
          os.uptime()
        ),
    };
  }


}
